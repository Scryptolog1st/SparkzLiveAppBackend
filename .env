PORT=3001
APP_NAME=liveapp-api
DATABASE_URL="postgresql://liveapp:liveapp_password@localhost:5432/liveapp?schema=public"

# Phase 2 auth
JWT_ACCESS_SECRET=dev_access_secret_change_me
JWT_REFRESH_SECRET=dev_refresh_secret_change_me
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Optional build metadata
GIT_COMMIT=
BUILT_AT=

JOBS_INTERVAL_MS=5000

STRIPE_WEBHOOK_SECRET=whsec_dev
STRIPE_WEBHOOK_TOLERANCE_SECONDS=300

# --- Apple VARs ---
IAP_APPLE_VERIFY_MODE=REAL
APPLE_BUNDLE_ID=com.sparkzlive.sparkzlive
APPLE_ENVIRONMENT=Sandbox
APPLE_ROOT_CERTS_DIR=certs/apple
APPLE_ENABLE_ONLINE_CHECKS=false

# --- Android VARs ---
IAP_GOOGLE_VERIFY_MODE=REAL
GOOGLE_PLAY_PACKAGE_NAME=com.sparkzlive.sparkzlive
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=REPLACE_WITH_NEW_BASE64_SERVICE_ACCOUNT_JSON

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret

PUSH_LIVE_TITLE_TEMPLATE={hostDisplayName} is live now
PUSH_LIVE_BODY_TEMPLATE={hostDisplayName} started: {streamTitle}
PUSH_LIVE_BODY_FALLBACK_TEMPLATE={hostDisplayName} started a live stream

PUSH_DM_TITLE_TEMPLATE=New message from {senderDisplayName}
PUSH_DM_BODY_TEMPLATE={senderDisplayName}: {messageText}
PUSH_DM_BODY_FALLBACK_TEMPLATE=Open SparkzLIVE to view your new message from {senderDisplayName}
PUSH_DM_IMAGE_BODY_TEMPLATE={senderDisplayName} sent you a photo
PUSH_DM_GIF_BODY_TEMPLATE={senderDisplayName} sent you a GIF
PUSH_DM_GIFT_BODY_TEMPLATE={senderDisplayName} sent you a gift

ADMIN_EMAILS=jgibbs.online@gmail.com, support@sparkzlive.com, dev@sparkzlive.com