import { z } from "zod";

const EnvSchema = z.object({
  PORT: z.coerce.number().int().positive().default(3001),
  APP_NAME: z.string().min(1).default("liveapp-api"),
  APP_WEB_URL: z.string().url().default("https://sparkzlive.com"),
  DATABASE_URL: z.string().min(1),

  // Phase 2: auth
  JWT_ACCESS_SECRET: z.string().min(10).default("dev_access_secret_change_me"),
  JWT_REFRESH_SECRET: z.string().min(10).default("dev_refresh_secret_change_me"),
  JWT_ACCESS_TTL_SECONDS: z.coerce.number().int().positive().default(900),
  JWT_REFRESH_TTL_SECONDS: z.coerce.number().int().positive().default(60 * 60 * 24 * 7),
  EMAIL_SECRET_ENCRYPTION_KEY: z.string().min(32),
  EMAIL_EMERGENCY_FALLBACK_SMTP_ACCOUNT_ID: z.string().uuid().optional().nullable(),
  EMAIL_TEST_SUBJECT_PREFIX: z.string().min(1).default("[SparkzLive Email Test]"),

  // Phase 6: video provider (LiveKit)
  LIVEKIT_URL: z.string().optional(),
  LIVEKIT_API_KEY: z.string().optional(),
  LIVEKIT_API_SECRET: z.string().optional(),

  // Push notification templates
  PUSH_LIVE_TITLE_TEMPLATE: z
    .string()
    .min(1)
    .default("{hostDisplayName} is live now"),
  PUSH_LIVE_BODY_TEMPLATE: z
    .string()
    .min(1)
    .default("{hostDisplayName} started: {streamTitle}"),
  PUSH_LIVE_BODY_FALLBACK_TEMPLATE: z
    .string()
    .min(1)
    .default("{hostDisplayName} started a live stream"),

  PUSH_DM_TITLE_TEMPLATE: z
    .string()
    .min(1)
    .default("New message from {senderDisplayName}"),
  PUSH_DM_BODY_TEMPLATE: z
    .string()
    .min(1)
    .default("{senderDisplayName}: {messageText}"),
  PUSH_DM_BODY_FALLBACK_TEMPLATE: z
    .string()
    .min(1)
    .default("Open SparkzLIVE to view your new message from {senderDisplayName}"),
  PUSH_DM_IMAGE_BODY_TEMPLATE: z
    .string()
    .min(1)
    .default("{senderDisplayName} sent you a photo"),
  PUSH_DM_GIF_BODY_TEMPLATE: z
    .string()
    .min(1)
    .default("{senderDisplayName} sent you a GIF"),
  PUSH_DM_GIFT_BODY_TEMPLATE: z
    .string()
    .min(1)
    .default("{senderDisplayName} sent you a gift"),

  // Optional build metadata
  GIT_COMMIT: z.string().optional().nullable(),
  BUILT_AT: z.string().optional().nullable(),
});

export type Env = z.infer<typeof EnvSchema>;

/**
 * Nest ConfigModule validate hook.
 * Throws at boot if required env vars are missing or invalid.
 */
export function envValidate(config: Record<string, unknown>) {
  const parsed = EnvSchema.safeParse(config);
  if (!parsed.success) {
    const pretty = parsed.error.issues
      .map((i) => `${i.path.join(".")}: ${i.message}`)
      .join("; ");
    throw new Error(`Invalid environment configuration: ${pretty}`);
  }
  return parsed.data;
}