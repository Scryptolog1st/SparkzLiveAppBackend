model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  username           String    @unique
  publicId           String    @unique @map("public_id") @db.VarChar(13)
  passwordHash       String    @map("password_hash")
  emailUpdatedAt     DateTime? @map("email_updated_at")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  lastUsernameChange DateTime? @map("last_username_change")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  profile       Profile?
  refreshTokens RefreshToken[]
  schedules     StreamSchedule[]

  milestones      DiamondMilestone[] @relation("MilestoneOwner")
  milestonesGiven DiamondMilestone[] @relation("MilestoneGiver")

  hostedStreams      Stream[]            @relation("StreamHost")
  streamParticipants StreamParticipant[]

  chatMessages ChatMessage[]

  streamHeartStatsSent   StreamHeartStat[] @relation("StreamHeartStatSender")
  streamHeartStatsHosted StreamHeartStat[] @relation("StreamHeartStatHost")

  streamRoles            StreamUserRole[]
  streamRolesAssigned    StreamUserRole[]        @relation("StreamRoleAssignedBy")
  streamStaffAssignments StreamStaffAssignment[] @relation("StreamStaffAssignmentUser")
  streamStaffAssignedBy  StreamStaffAssignment[] @relation("StreamStaffAssignmentAssignedBy")
  streamRestrictions     StreamUserRestriction[]
  restrictionsCreated    StreamUserRestriction[] @relation("RestrictionCreatedBy")
  moderationAsActor      ModerationAction[]      @relation("ModerationActor")
  moderationAsTarget     ModerationAction[]      @relation("ModerationTarget")

  wallet              Wallet?
  walletLedgerEntries WalletLedger[]
  giftsSent           GiftTransaction[] @relation("GiftSender")
  giftsReceived       GiftTransaction[] @relation("GiftRecipient")

  battlesAsHost         Battle[]             @relation("BattleHost")
  battlesAsOpponent     Battle[]             @relation("BattleOpponent")
  battlesWon            Battle[]             @relation("BattleWinner")
  battleContribSent     BattleContribution[] @relation("BattleContributionSender")
  battleContribReceived BattleContribution[] @relation("BattleContributionRecipient")

  purchaseOrders PurchaseOrder[]
  vipMonths      UserVipMonth[]

  favorites           UserFavorite[]       @relation("UserFavorites")
  favoritedBy         UserFavorite[]       @relation("UserFavoritedBy")
  streamGuestRequests StreamGuestRequest[]

  twoFactorEnabled     Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret      String?  @map("two_factor_secret")
  twoFactorBackupCodes String[]

  blocksCreated UserBlock[] @relation("Blocker")
  blockedBy     UserBlock[] @relation("Blocked")

  dmUnlockGiftId    String?         @map("dm_unlock_gift_id")
  dmUnlockGift      Gift?           @relation("UserDmUnlockGift", fields: [dmUnlockGiftId], references: [id], onDelete: SetNull)
  conversationsAsP1 Conversation[]  @relation("ConversationParticipant1")
  conversationsAsP2 Conversation[]  @relation("ConversationParticipant2")
  directMessages    DirectMessage[] @relation("DirectMessageSender")

  payoutRequests PayoutRequest[]

  notificationPushEnabled       Boolean @default(true) @map("notification_push_enabled")
  notificationLiveAlertsEnabled Boolean @default(true) @map("notification_live_alerts_enabled")
  notificationMarketingEnabled  Boolean @default(false) @map("notification_marketing_enabled")

  streamOptionsOrder String[] @default([]) @map("stream_options_order")

  pushDeviceTokens PushDeviceToken[]

  notifications Notification[]

  submittedReports Report[] @relation("ReportReporter")
  reportsAsTarget  Report[] @relation("ReportTargetUser")

  assetSubmissions         AssetSubmission[] @relation("AssetSubmissionUser")
  reviewedAssetSubmissions AssetSubmission[] @relation("AssetSubmissionReviewer")

  coinLots         CoinLot[]
  streamerEarnings StreamerEarning[] @relation("StreamerEarnings")
  payoutMethods    PayoutMethod[]

  feedPosts        FeedPost[]        @relation("FeedPostAuthor")
  storyPosts       StoryPost[]       @relation("StoryPostAuthor")
  feedPostLikes    FeedPostLike[]    @relation("FeedPostLikeUser")
  feedPostComments FeedPostComment[] @relation("FeedPostCommentAuthor")

  advertisements                  Advertisement[]             @relation("AdvertisementOwner")
  advertisementRevisionsSubmitted AdvertisementRevision[]     @relation("AdvertisementRevisionSubmitter")
  advertisementBillingEvents      AdvertisementBillingEvent[]
  advertisementJobsAsAdvertiser   AdvertisementJob[]          @relation("AdvertisementJobAdvertiser")
  advertisementJobsAsCustomer     AdvertisementJob[]          @relation("AdvertisementJobCustomer")
  advertisementReviewsGiven       AdvertisementReview[]       @relation("AdvertisementReviewReviewer")
  advertisementReviewsReceived    AdvertisementReview[]       @relation("AdvertisementReviewAdvertiser")

  isPlatformBanned            Boolean     @default(false) @map("is_platform_banned")
  platformBanIssuedAt         DateTime?   @map("platform_ban_issued_at")
  platformBanExpiresAt        DateTime?   @map("platform_ban_expires_at")
  platformBanReason           String?     @map("platform_ban_reason") @db.VarChar(300)
  platformBannedByAdminUserId String?     @map("platform_banned_by_admin_user_id") @db.Uuid
  forceLogoutAt               DateTime?   @map("force_logout_at")
  banAppeals                  BanAppeal[]
  assignedBadges              UserBadge[]


  battleSessionsCreatedV2       BattleSession[]          @relation("BattleSessionCreatedBy")
  battleSidesHostedV2           BattleSide[]             @relation("BattleSideHost")
  battleParticipantsV2          BattleParticipant[]      @relation("BattleParticipantUser")
  battleInvitesSentV2           BattleInvite[]           @relation("BattleInviteSender")
  battleInvitesReceivedV2       BattleInvite[]           @relation("BattleInviteRecipient")
  battleRandomQueueEntriesV2    BattleRandomQueueEntry[] @relation("BattleRandomQueueHost")
  battleRematchVotesV2          BattleRematchVote[]      @relation("BattleRematchVoteUser")
  battleSideContribSentV2       BattleSideContribution[] @relation("BattleSideContributionSender")
  battleSideContribReceivedV2   BattleSideContribution[] @relation("BattleSideContributionRecipient")

  @@map("users")
}

model AdminUser {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  name               String
  passwordHash       String    @map("password_hash")
  role               AdminRole @default(ADMIN)
  isActive           Boolean   @default(true) @map("is_active")
  forcePasswordReset Boolean   @default(false) @map("force_password_reset")
  createdById        String?   @map("created_by_id") @db.Uuid
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  assignedReports Report[]         @relation("ReportAssignedAdmin")
  reportAuditLogs ReportAuditLog[] @relation("ReportAuditActor")
  adminAuditLogs  AdminAuditLog[]  @relation("AdminAuditActor")

  moderationActionsAsAdminActor ModerationAction[]      @relation("AdminModerationActor")
  restrictionsCreatedAsAdmin    StreamUserRestriction[] @relation("AdminRestrictionCreatedBy")

  reviewedAdvertisementRevisions AdvertisementRevision[] @relation("AdvertisementRevisionReviewer")
  pausedAdvertisements           Advertisement[]         @relation("AdvertisementPausedByAdmin")

  reviewedBanAppeals BanAppeal[] @relation("BanAppealReviewer")

  @@index([role])
  @@index([isActive])
  @@index([createdById])
  @@map("admin_users")
}

model AdminRolePermission {
  id         String    @id @default(uuid()) @db.Uuid
  role       AdminRole
  permission String    @db.VarChar(120)
  enabled    Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([role, permission])
  @@index([role])
  @@index([role, enabled])
  @@map("admin_role_permissions")
}

model AdminAuditLog {
  id               String    @id @default(uuid()) @db.Uuid
  actorAdminUserId String    @map("actor_admin_user_id") @db.Uuid
  actorEmail       String    @map("actor_email") @db.VarChar(255)
  actorName        String    @map("actor_name") @db.VarChar(160)
  actorRole        AdminRole @map("actor_role")

  actionType  AdminAuditActionType @map("action_type")
  actionCode  String               @map("action_code") @db.VarChar(160)
  actionLabel String               @map("action_label") @db.VarChar(255)

  resourceType String  @map("resource_type") @db.VarChar(120)
  resourceId   String? @map("resource_id") @db.VarChar(120)

  status   AdminAuditStatus   @default(SUCCESS)
  severity AdminAuditSeverity @default(INFO)

  targetUserId          String? @map("target_user_id") @db.Uuid
  targetStreamId        String? @map("target_stream_id") @db.Uuid
  targetReportId        String? @map("target_report_id") @db.Uuid
  targetPayoutRequestId String? @map("target_payout_request_id") @db.Uuid
  targetSupportTicketId String? @map("target_support_ticket_id") @db.VarChar(120)

  targetSummaryJson        Json? @map("target_summary_json")
  secondaryIdentifiersJson Json? @map("secondary_identifiers_json")
  referencesJson           Json? @map("references_json")

  requestPath   String? @map("request_path") @db.VarChar(500)
  ipAddress     String? @map("ip_address") @db.VarChar(128)
  locationLabel String? @map("location_label") @db.VarChar(255)
  deviceLabel   String? @map("device_label") @db.VarChar(255)
  userAgent     String? @map("user_agent") @db.VarChar(1000)

  beforeStateJson Json? @map("before_state_json")
  afterStateJson  Json? @map("after_state_json")
  diffJson        Json? @map("diff_json")
  metadataJson    Json? @map("metadata_json")
  rawEventJson    Json? @map("raw_event_json")

  createdAt DateTime @default(now()) @map("created_at")

  actorAdminUser AdminUser @relation("AdminAuditActor", fields: [actorAdminUserId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([actorAdminUserId, createdAt])
  @@index([actorRole, createdAt])
  @@index([actionType, createdAt])
  @@index([actionCode, createdAt])
  @@index([resourceType, createdAt])
  @@index([resourceId, createdAt])
  @@index([status, createdAt])
  @@index([severity, createdAt])
  @@index([targetUserId, createdAt])
  @@index([targetStreamId, createdAt])
  @@index([targetReportId, createdAt])
  @@index([targetPayoutRequestId, createdAt])
  @@index([targetSupportTicketId, createdAt])
  @@map("admin_audit_logs")
}

model PayoutRequest {
  id            String       @id @default(uuid()) @db.Uuid
  userId        String       @map("user_id") @db.Uuid
  diamondAmount Int          @map("diamond_amount")
  netAmount     Int          @map("net_amount_cents")
  status        PayoutStatus @default(PENDING)

  idempotencyKey String? @map("idempotency_key") @db.VarChar(120)

  provider PayoutProvider @default(MANUAL)

  grossAmount Int @default(0) @map("gross_amount_cents")
  feeAmount   Int @default(0) @map("fee_amount_cents")

  payoutMethodId String? @map("payout_method_id") @db.Uuid

  paymentMethod  String? @map("payment_method")
  paymentDetails Json?   @map("payment_details")

  providerBatchId  String? @map("provider_batch_id")
  providerPayoutId String? @map("provider_payout_id")
  providerStatus   String? @map("provider_status")
  providerResponse Json?   @map("provider_response")

  adminNotes  String?   @map("admin_notes")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  processedAt DateTime? @map("processed_at")
  paidAt      DateTime? @map("paid_at")
  failedAt    DateTime? @map("failed_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  payoutMethod PayoutMethod? @relation(fields: [payoutMethodId], references: [id], onDelete: SetNull)

  earnings StreamerEarning[]

  @@unique([userId, idempotencyKey])
  @@index([userId, status])
  @@index([createdAt])
  @@index([provider, providerPayoutId])
  @@index([payoutMethodId])
  @@map("payout_requests")
}

model UserFavorite {
  userId         String   @map("user_id") @db.Uuid
  favoriteUserId String   @map("favorite_user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  user         User @relation("UserFavorites", fields: [userId], references: [id], onDelete: Cascade)
  favoriteUser User @relation("UserFavoritedBy", fields: [favoriteUserId], references: [id], onDelete: Cascade)

  @@id([userId, favoriteUserId])
  @@index([userId, createdAt])
  @@index([favoriteUserId, createdAt])
  @@map("user_favorites")
}

model Profile {
  userId             String       @id @map("user_id") @db.Uuid
  displayName        String       @map("display_name")
  bio                String?      @db.VarChar(1000)
  wifw               Json?
  avatarUrl          String?      @map("avatar_url")
  bannerUrl          String?      @map("banner_url")
  linksJson          Json?        @map("links_json")
  badgeLabel         String?      @map("badge_label") @db.VarChar(80)
  badgeTone          String?      @map("badge_tone") @db.VarChar(32)
  vipDisplayBadgeKey VipBadgeKey? @map("vip_display_badge_key")
  vipLockedBadgeKey  VipBadgeKey? @map("vip_locked_badge_key")
  vipLiveBadgeKey    VipBadgeKey? @map("vip_live_badge_key")
  vipLockedPeriodKey String?      @map("vip_locked_period_key") @db.VarChar(7)
  showBadgeOnProfile Boolean      @default(true) @map("show_badge_on_profile")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([vipDisplayBadgeKey])
  @@index([vipLockedBadgeKey])
  @@map("profiles")
}

model FeedPost {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  imageUrl  String    @map("image_url") @db.VarChar(1000)
  caption   String?   @db.VarChar(500)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user     User              @relation("FeedPostAuthor", fields: [userId], references: [id], onDelete: Cascade)
  likes    FeedPostLike[]
  comments FeedPostComment[]

  @@index([deletedAt, createdAt])
  @@index([userId, createdAt])
  @@map("feed_posts")
}

model FeedPostLike {
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation("FeedPostLikeUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@map("feed_post_likes")
}

model FeedPostComment {
  id        String    @id @default(uuid()) @db.Uuid
  postId    String    @map("post_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  text      String    @db.VarChar(500)
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  post FeedPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation("FeedPostCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, deletedAt, createdAt])
  @@index([userId, createdAt])
  @@map("feed_post_comments")
}

model StoryPost {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  mediaUrl  String    @map("media_url") @db.VarChar(1000)
  caption   String?   @db.VarChar(500)
  expiresAt DateTime  @map("expires_at")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation("StoryPostAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt, deletedAt, createdAt])
  @@index([userId, createdAt])
  @@map("story_posts")
}

model AdvertisementSettings {
  id                        String    @id @default("default")
  enabled                   Boolean   @default(true)
