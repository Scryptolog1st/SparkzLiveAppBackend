enum InAppAlertStatus {
  DRAFT
  ACTIVE
  DISABLED
  EXPIRED
}

enum InAppAlertCadence {
  ONCE_EVER
  ONCE_DAILY
  EVERY_APP_START
  CRON
  EVENT_TRIGGERED
  EVENT_ONCE
}

enum InAppAlertDeliveryAction {
  SHOWN
  ACKNOWLEDGED
  DISMISSED
}

model InAppAlert {
  id                 String            @id @default(uuid()) @db.Uuid
  title              String            @db.VarChar(140)
  body               String
  footerText         String?           @map("footer_text") @db.VarChar(500)
  confirmButtonLabel String            @default("OK") @map("confirm_button_label") @db.VarChar(60)
  status             InAppAlertStatus  @default(DRAFT)
  priority           Int               @default(0)
  startAt            DateTime          @default(now()) @map("start_at")
  endAt              DateTime?         @map("end_at")
  cadence            InAppAlertCadence @default(ONCE_EVER)
  cronExpression     String?           @map("cron_expression") @db.VarChar(120)
  eventTriggerKey    String?           @map("event_trigger_key") @db.VarChar(120)

  targetAllUsers Boolean  @default(true) @map("target_all_users")
  targetRoles    String[] @default([]) @map("target_roles")
  targetUserIds  String[] @default([]) @map("target_user_ids") @db.Uuid
  targetPlatforms String[] @default([]) @map("target_platforms")
  minAppVersion  String?  @map("min_app_version") @db.VarChar(40)
  maxAppVersion  String?  @map("max_app_version") @db.VarChar(40)

  metadataJson Json? @map("metadata_json")

  createdByAdminUserId String? @map("created_by_admin_user_id") @db.Uuid
  updatedByAdminUserId String? @map("updated_by_admin_user_id") @db.Uuid

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  deliveries InAppAlertDelivery[]

  @@index([status, startAt, endAt])
  @@index([eventTriggerKey, status, priority])
  @@index([priority, createdAt])
  @@index([deletedAt])
  @@map("in_app_alerts")
}

model InAppAlertDelivery {
  id              String                    @id @default(uuid()) @db.Uuid
  alertId         String                    @map("alert_id") @db.Uuid
  userId          String                    @map("user_id") @db.Uuid
  eventTriggerKey String?                   @map("event_trigger_key") @db.VarChar(120)
  firstShownAt    DateTime?                 @map("first_shown_at")
  lastShownAt     DateTime?                 @map("last_shown_at")
  impressionCount Int                       @default(0) @map("impression_count")
  acknowledgedAt  DateTime?                 @map("acknowledged_at")
  dismissedAt     DateTime?                 @map("dismissed_at")
  lastAction      InAppAlertDeliveryAction? @map("last_action")
  metadataJson    Json?                     @map("metadata_json")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  alert InAppAlert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@unique([alertId, userId])
  @@index([userId, lastShownAt])
  @@index([alertId, acknowledgedAt])
  @@index([alertId, dismissedAt])
  @@map("in_app_alert_deliveries")
}
